{
  "version": "1.3",
  "comment": "Configuration template for Lumen kernel debug workflow.",
  "note": "Variables like ${HOME} are substituted from environment. Copy to config.json and set your env vars.",
  "default": {
    "backend": "anthropic",
    "api_key": "${ANTHROPIC_API_KEY:-}",
    "base_url": "${ANTHROPIC_BASE_URL:-https://api.deepseek.com/anthropic}",
    "model_name": "${ANTHROPIC_MODEL:-deepseek-v4-flash}",
    "temperature": 0,
    "http_timeout": 120
  },
  "agents": {
    "validator": {
      "prompt_file": "prompts/validator.md"
    },
    "pm": {
      "prompt_file": "prompts/pm.md"
    },
    "kernel_expert": {
      "prompt_file": "prompts/kernel_expert.md",
      "backend": "claude_code",
      "cli_command": "claude",
      "model": "sonnet",
      "cli_timeout": 14400,
      "permission_mode": "bypassPermissions",
      "max_turns": 900,
      "disable_skills": true,
      "settings_file": "${CLAUDE_SETTINGS_PATH:-${HOME}/.claude/settings-lumen-deepseek.json}",
      "semcode_mcp": {
        "command": "${LUMEN_SEMCODE_MCP:-${LUMEN_PROJECT_ROOT:-.}/Analysis-SKILL/tools/semcode/target/release/semcode-mcp}",
        "args": []
      }
    },
    "_kernel_expert_settings_file_note": {
      "_comment": "settings_file isolates the Claude Code CLI invocation that kernel_expert spawns from the user's global ~/.claude/settings.json. Without this, Claude Code CLI inherits whatever ANTHROPIC_AUTH_TOKEN / ANTHROPIC_BASE_URL the shell or global settings provide, so kernel_expert would silently call the wrong model. The settings file MUST set ANTHROPIC_AUTH_TOKEN (NOT ANTHROPIC_API_KEY) — Claude Code CLI prefers the former and falls back to global settings.json if only the latter is set. A working DeepSeek settings file lives at ~/.claude/settings-lumen-deepseek.json by default; override the path with the CLAUDE_SETTINGS_PATH env var. See DEPLOYMENT.md §4.4."
    },
    "_kernel_expert_opencode_alt": {
      "_comment": "Alternate kernel_expert config for environments without Claude Code. Copy these fields over kernel_expert above and remove the _alt prefix. OpenCode requires `opencode` CLI installed (curl -fsSL https://opencode.ai/install | bash) and a provider configured in ~/.config/opencode/opencode.jsonc (e.g., `opencode providers add`). semcode MCP must be registered via `opencode mcp add semcode <command> -- -d <db>` (no CLI flag injection).",
      "backend": "opencode",
      "cli_command": "opencode",
      "model": "${OPENCODE_MODEL:-deepseek/deepseek-chat}",
      "agent_name": "lumen_kernel_expert",
      "cli_timeout": 3600,
      "pure": false
    },
    "knowledge_base": {
      "prompt_file": "prompts/knowledge_base.md"
    }
  },
  "tool_experts": [
    {
      "type": "knowledge_search",
      "name": "历史知识库搜索专家",
      "description": "搜索历史知识库，查找与当前问题相似的历史案例和解决方案",
      "agent": {
        "prompt_file": "prompts/knowledge_search.md"
      }
    },
    {
      "type": "lock_analysis",
      "name": "锁分析专家",
      "description": "分析内核锁相关问题，包括死锁、锁竞争、锁顺序等",
      "agent": {
        "prompt_file": "prompts/lock_analysis.md",
        "semcode_mcp": {
          "command": "${LUMEN_SEMCODE_MCP:-${LUMEN_PROJECT_ROOT:-.}/Analysis-SKILL/tools/semcode/target/release/semcode-mcp}",
          "args": []
        }
      }
    },
    {
      "type": "crash_analysis",
      "name": "Crash分析专家",
      "description": "分析 Crash 日志，定位崩溃原因和调用栈",
      "agent": {
        "prompt_file": "prompts/crash_analysis.md",
        "semcode_mcp": {
          "command": "${LUMEN_SEMCODE_MCP:-${LUMEN_PROJECT_ROOT:-.}/Analysis-SKILL/tools/semcode/target/release/semcode-mcp}",
          "args": []
        }
      }
    },
    {
      "type": "kernel_log_analysis",
      "name": "内核日志分析专家",
      "description": "分析内核日志（dmesg/logcat等），提取关键错误信息和异常模式",
      "agent": {
        "prompt_file": "prompts/kernel_log_analysis.md"
      }
    }
  ],
  "knowledge_base": {
    "output_dir": "knowledge_base"
  },
  "workflow": {
    "max_reproduction_rounds": 9,
    "hint_wait_seconds": 0
  }
}
