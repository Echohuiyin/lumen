{
  "version": "1.0",
  "_comment": "Self-test workflow configuration for iterative agent validation",
  "default": {
    "backend": "openai",
    "api_key": "your-api-key-here",
    "base_url": "https://api.openai.com/v1",
    "model_name": "gpt-4o-mini",
    "temperature": 0
  },
  "skills": {
    "kernel_fault_injection": {
      "path": "./skills/kernel-fault-injection",
      "scripts": {
        "run": "scripts/run_fault_injection.sh"
      }
    },
    "kernel_build": {
      "path": "./skills/kernel-build"
    },
    "qemu_test": {
      "path": "./skills/qemu-test"
    },
    "vmcore_analyzer": {
      "path": "./skills/vmcore-analyzer"
    }
  },
  "kernel": {
    "source_dir": "/path/to/kernel/source",
    "vmlinux_path": "/path/to/vmlinux",
    "default_arch": "x86_64"
  },
  "agents": {
    "validator": {
      "prompt_file": "prompts/maintenance/validator.md"
    },
    "pm": {
      "prompt_file": "prompts/maintenance/pm.md"
    },
    "kernel_expert": {
      "prompt_file": "prompts/maintenance/kernel_expert.md"
    },
    "test_expert": {
      "prompt_file": "prompts/maintenance/test_expert.md"
    },
    "knowledge_base": {
      "prompt_file": "prompts/maintenance/knowledge_base.md"
    },
    "evaluation": {
      "prompt_file": "prompts/self_test/evaluation.md"
    },
    "improvement": {
      "prompt_file": "prompts/self_test/improvement.md"
    }
  },
  "tool_experts": [
    {
      "type": "knowledge_search",
      "name": "历史知识库搜索专家",
      "description": "搜索历史知识库，查找与当前问题相似的历史案例和解决方案",
      "agent": {
        "prompt_file": "prompts/maintenance/knowledge_search.md"
      }
    },
    {
      "type": "crash_analysis",
      "name": "Crash分析专家",
      "description": "分析 Crash 日志，定位崩溃原因和调用栈",
      "agent": {
        "prompt_file": "prompts/maintenance/crash_analysis.md"
      }
    },
    {
      "type": "kernel_log_analysis",
      "name": "内核日志分析专家",
      "description": "分析内核日志（dmesg/logcat等），提取关键错误信息和异常模式",
      "agent": {
        "prompt_file": "prompts/maintenance/kernel_log_analysis.md"
      }
    }
  ],
  "self_test": {
    "max_iterations": 5,
    "target_score": 90,
    "output_dir": "self_test_reports",
    "fault_types": ["nullptr", "softlockup", "deadlock"]
  },
  "workflow": {
    "max_test_attempts": 3
  }
}